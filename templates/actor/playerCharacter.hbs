<forum class="{{cssClass}}">
    <header>
        <h1 class="characterName">
            <input name="name" type="text" value="{{actor.name}}" placeholder="Character Name" />
        </h1>
        <div class="sequence-title">
            <label>Sequence Title:</label>
            <input name="system.sequenceTitle" type="text" value="{{system.sequenceTitle}}" placeholder="(Sequence Name)" />
        </div>
        <!--TODO: Age, Occupation, Race, Gender-->>
    </header>

    <div class="sheet-body">
        <!--Left Column: Quick Use-->>
        <selection class="columnSidebar">
            <div class="panelQuickUse">
                <div class="healthSpiritRationality">
                    <label>Health</label>
                    <div class="healthInputGroup">
                        <input type="text" name="system.health.value" value="{{system.health.value}}" /> /
                        <input type="text" name="system.health.max" value="{{system.health.max}}" />
                    </div>
                </div>
                <div class="healthSpiritRationality">
                    <label>Spirit</label>
                    <div class="spiritInputGroup">
                        <input type="text" name="system.spirit.value" value="{{system.spirit.value}}" /> /
                        <input type="text" name="system.spirit.max" value="{{system.spirit.max}}" />
                    </div>
                </div>
                <div class="healthSpiritRationality">
                    <label>Rationality</label>
                    <div class="rationalityInputGroup">
                        <input type="text" name="system.rationality.value" value="{{system.rationality.value}}" /> /
                        <input type="text" name="system.rationality.max" value="{{system.rationality.max}}" />
                    </div>
                </div>
                <div class="restButtons">
                    <label>Long Rest</label>
                    <input type="text" name="system.longRest" value="{{system.longRest}}" />
                </div>
                <div class="shortButtons">
                    <label>Short Rest</label>
                    <input type="text" name="system.shortRest" value="{{system.shortRest}}" />
                </div>
                <div class="defenses">
                    <label>Armor</label>
                    <input type="text" name="system.armor" value="{{system.armor}}" placeholder="0" />
                </div>
                <div class="defenses">
                    <label>Physical</label>
                    <input type="text" name="system.physical" value="{{system.physical}}" placeholder="0" />
                </div>
                <div class="defenses">
                    <label>Will</label>
                    <input type="text" name="system.will" value="{{system.will}}" placeholder="0" />
                </div>
                <div class="defenses">
                    <label>Damage Resistance</label>
                    <input type="text" name="system.damageResistance" value="{{system.damageResistance}}" placeholder="0" />
                </div>
                <div class="consumableSpiritLuck">
                <label>Spirituality</label>
                    <input type="text" name="system.spirituality" value="{{system.spirituality}}" />
                </div>
                <div class="consumableSpiritLuck">
                    <label>Luck</label>
                    <input type="text" name="system.luck" value="{{system.luck}}" />
                </div>
                <div class="consumableSpiritLuck">
                    <label>Spend</label>
                    <input type="text" name="system.spend" value="{{system.spend}}" />
                </div>
            </div>
        </selection>
        
        <!--Center Tabs-->
        <selection class="centerTabs">
            <div class="panel character-info">
                <h2>Character Info</h2>
        
                <div class="basic-details-grid">
                    <div class="form-group">
                        <label>Age</label>
                        <input type="text" name="system.age" value="{{system.age}}" />
                    </div>
                    <div class="form-group">
                        <label>Occupation</label>
                        <input type="text" name="system.occupation" value="{{system.occupation}}" />
                    </div>
                    <div class="form-group">
                        <label>Race</label>
                        <input type="text" name="system.race" value="{{system.race}}" />
                    </div>
                    <div class="form-group">
                        <label>Gender</label>
                        <input type="text" name="system.gender" value="{{system.gender}}" />
                    </div>
                </div>

                <!-- Attributes Section -->
                <div class="attributes-section">
                    <h3>Attributes</h3>
                    <div class="attr-grid">
                        {{#each system.attributes as |attr key|}}
                        <div class="form-group stacked">
                            <label>{{attr.label}}</label>
                                <div class="attr-input-wrapper">
                                    <input type="text" name="system.attributes.{{key}}.value" value="{{attr.value}}" placeholder="###" />
                                    <span class="attr-formula">({{attr.formula}})</span>
                                </div>
                        </div>
                        {{/each}}
                    </div>
                </div>

                <!-- Languages -->
                <div class="languages-section">
                    <h3>Languages</h3>
                    <div class="form-group">
                        <label>Normal</label>
                        <textarea name="system.languages.normal" rows="2">{{system.languages.normal}}</textarea>
                    </div>
                    <div class="form-group">
                        <label>Mystical</label>
                        <textarea name="system.languages.mystical" rows="2">{{system.languages.mystical}}</textarea>
                    </div>
                </div>
            </div>

            <!-- Tab Navigation -->
            <nav class="sheet-tabs tabs" data-group="primary">
                <a class="item" data-tab="biography">Biography</a>
                <a class="item" data-tab="details">Physical & Misc</a>
            </nav>
        </section>

        <!-- RIGHT COLUMN / TAB CONTENT: Biography & Details -->
        <selection class="column content">
            <div class="tab" data-group="primary" data-tab="biography">
                <div class="panel biography-panel">
                <h2>Biography</h2>
                <div class="form-group">
                    <label>Physical Description</label>
                    <textarea name="system.description.physical" rows="4">{{system.description.physical}}</textarea>
                </div>
                <div class="form-group">
                    <label>Backstory</label>
                    <textarea name="system.biography.backstory" rows="6">{{system.biography.backstory}}</textarea>
                </div>
                <div class="form-group">
                    <label>Ideas & Beliefs</label>
                    <textarea name="system.biography.beliefs" rows="3">{{system.biography.beliefs}}</textarea>
                </div>
                <div class="form-group">
                    <label>Prized Possession</label>
                    <input type="text" name="system.biography.possession" value="{{system.biography.possession}}" />
                </div>
                <div class="form-group">
                    <label>Favorite Things</label>
                    <input type="text" name="system.biography.favorites" value="{{system.biography.favorites}}" />
                </div>
                <div class="form-group">
                    <label>Dislikes</label>
                    <input type="text" name="system.biography.dislikes" value="{{system.biography.dislikes}}" />
                </div>
                </div>
            </div>

            <div class="tab" data-group="primary" data-tab="details">
                <div class="panel details-panel">
                    <h2>Physical Details</h2>
                    <div class="basic-details-grid">
                        <div class="form-group">
                            <label>Height</label>
                            <input type="text" name="system.physical.height" value="{{system.physical.height}}" />
                        </div>
                        <div class="form-group">
                            <label>Weight</label>
                            <input type="text" name="system.physical.weight" value="{{system.physical.weight}}" />
                        </div>
                        <div class="form-group">
                            <label>Birth Date</label>
                            <input type="text" name="system.birth.date" value="{{system.birth.date}}" />
                        </div>
                        <div class="form-group">
                            <label>Birth Place</label>
                            <input type="text" name="system.birth.place" value="{{system.birth.place}}" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Religion</label>
                        <input type="text" name="system.religion" value="{{system.religion}}" />
                    </div>
                </div>
            </div>
        </section>
        </select>

    </div>

</forum>
